# deploy/.env — production VPS unique (full self-host)
# Copier en deploy/.env et remplir. NE PAS committer.

# --- Postgres (conteneur local) ---
POSTGRES_USER=ganndal
POSTGRES_PASSWORD=change-moi-mot-de-passe-fort
POSTGRES_DB=ganndal

# --- Backend ---
NODE_ENV=production
PORT=4000
# Le backend parle à Postgres via le réseau docker (host = postgres)
DATABASE_URL=postgresql://ganndal:change-moi-mot-de-passe-fort@postgres:5432/ganndal?schema=public
DIRECT_URL=postgresql://ganndal:change-moi-mot-de-passe-fort@postgres:5432/ganndal?schema=public

# Secrets JWT (générer: openssl rand -hex 32)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# CORS : même origine (nginx sert front + api) => URL publique du site
CORS_ORIGIN=https://ganndal.media

# --- Stockage MinIO (conteneur local, pas de limite de taille) ---
S3_ACCESS_KEY=ganndal-minio
S3_SECRET_KEY=change-moi-minio-secret
S3_BUCKET=ganndal
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true
# URL publique des fichiers (servis via nginx -> /files, voir note DEPLOY_VPS.md)
S3_PUBLIC_URL=https://ganndal.media/files/ganndal

# --- Frontend (build-arg) : même origine => /api ---
PUBLIC_API_URL=/api

# --- Email SMTP (optionnel) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=GANNDAL <no-reply@ganndal.media>

# --- WhatsApp Cloud API (optionnel) ---
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
