# Serveur
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Base de données
# --- Dev local (Docker) ---
DATABASE_URL="postgresql://ganndal:ganndal@localhost:5432/ganndal?schema=public"
DIRECT_URL="postgresql://ganndal:ganndal@localhost:5432/ganndal?schema=public"
# --- Supabase (décommenter, remplacer [REF]/[PASSWORD]/[REGION]) ---
# Pooler (runtime, transaction mode, port 6543) :
# DATABASE_URL="postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Connexion directe (migrations, port 5432) :
# DIRECT_URL="postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# JWT
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Stockage S3 compatible
# --- Dev local (MinIO) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=ganndal
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_URL=http://localhost:9000/ganndal
# --- Supabase Storage (Storage > Settings > S3 connection) ---
# S3_ENDPOINT=https://[REF].storage.supabase.co/storage/v1/s3
# S3_REGION=[REGION]                       # ex: eu-west-3
# S3_BUCKET=ganndal                         # créer le bucket dans le dashboard
# S3_ACCESS_KEY=[S3_ACCESS_KEY_ID]
# S3_SECRET_KEY=[S3_SECRET_ACCESS_KEY]
# S3_FORCE_PATH_STYLE=true
# S3_PUBLIC_URL=https://[REF].supabase.co/storage/v1/object/public/ganndal

# Email SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="GANNDAL <no-reply@ganndal.media>"

# WhatsApp Cloud API (optionnel)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
